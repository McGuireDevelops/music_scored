rules_version = '2';
// Professional Film Music Learning Platform – Firestore security rules.
// Role-based: student, teacher, admin. Access uses AccessGrant + role only; no payment in access path.
// IMPORTANT: Firestore limits rules to 10 get()/exists() calls per evaluation.
// All helpers share a single get() for the user doc via cachedRole().

service cloud.firestore {
  match /databases/{database}/documents {

    // Single get() for the authenticated user's role — every helper should use this
    // instead of calling get() on the user doc independently.
    function cachedRole() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc.exists == true ? userDoc.data.get('role', null) : null;
    }

    function isTeacher() {
      return request.auth != null && cachedRole() == 'teacher';
    }

    function isStudent() {
      return request.auth != null && cachedRole() == 'student';
    }

    function isAdmin() {
      return request.auth != null && cachedRole() == 'admin';
    }

    // Check if the authenticated user is the teacher who owns this class.
    // Costs: 1 get (cachedRole) + 1 get (class doc) = 2 gets.
    function isClassTeacher(classId) {
      return request.auth != null && cachedRole() == 'teacher'
        && get(/databases/$(database)/documents/classes/$(classId)).data.teacherId == request.auth.uid;
    }

    // Lightweight ownership check that skips the role lookup — use when the caller
    // already verified the role or when combined with isClassTeacher in an OR chain.
    // Costs: 1 get (class doc).
    function ownsClass(classId) {
      return get(/databases/$(database)/documents/classes/$(classId)).data.teacherId == request.auth.uid;
    }

    // Student has a valid time-bound access grant for the class.
    // Costs: 1 exists + 1 get (grant doc) = 2 calls.
    function hasStudentGrant(classId) {
      let grantPath = /databases/$(database)/documents/users/$(request.auth.uid)/accessGrants/$(classId);
      return exists(grantPath)
        && get(grantPath).data.validFrom <= request.time.toMillis()
        && get(grantPath).data.validTo >= request.time.toMillis();
    }

    // Full access-grant check including teacher-owns and admin bypass.
    // Costs: 1 get (cachedRole) + at most 2 more (class doc or grant doc).
    function hasValidAccessGrant(classId) {
      let role = cachedRole();
      return request.auth != null && (
        role == 'admin'
        || (role == 'teacher' && ownsClass(classId))
        || (role == 'student' && hasStudentGrant(classId))
      );
    }

    // Student can access class content only if they have a valid grant AND have
    // fulfilled mandatory entry requirements (NDA, end-user agreement, etc.).
    // Costs: 1 get (cachedRole) + 2 (grant) + 1 get (class doc) + 1 get (enrollment) = 5 max.
    function hasFulfilledMandatoryRequirements(classId) {
      let classDoc = get(/databases/$(database)/documents/classes/$(classId));
      let mandatoryIds = classDoc.exists && classDoc.data != null ? classDoc.data.get('mandatoryRequirementIds', []) : [];
      return mandatoryIds.size() == 0
        || (exists(/databases/$(database)/documents/classes/$(classId)/enrollments/$(request.auth.uid))
            && get(/databases/$(database)/documents/classes/$(classId)/enrollments/$(request.auth.uid)).data.get('status', 'enrolled') == 'enrolled');
    }

    function studentCanAccessClassContent(classId) {
      return request.auth != null && cachedRole() == 'student'
        && hasStudentGrant(classId) && hasFulfilledMandatoryRequirements(classId);
    }

    // Live lesson teaching plan: class owner or live-lesson creator; 1 get on liveLessons/{id}.
    function canAccessLiveLessonTeacherPlan(lessonId) {
      let ll = get(/databases/$(database)/documents/liveLessons/$(lessonId));
      return request.auth != null && ll.exists && (
        isAdmin()
        || ll.data.ownerId == request.auth.uid
        || ownsClass(ll.data.classId)
      );
    }

    // Users: own doc; admin read/update all; teachers can read (for roster/student list)
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin() || isTeacher());
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // AccessGrants (top-level for listing): written by backend/payment; students read own
    match /accessGrants/{grantId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    // Per-class access grant for rule evaluation: users/{uid}/accessGrants/{classId} with validFrom, validTo
    match /users/{userId}/accessGrants/{classId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // only Cloud Functions / Admin SDK
    }

    // Classes: teacher CRUD own; admin can create/read; student read if has valid AccessGrant and fulfilled mandatory entry requirements
    match /classes/{classId} {
      allow read: if request.auth != null && (
        resource.data.teacherId == request.auth.uid
        || studentCanAccessClassContent(classId)
        || isAdmin()
      );
      allow create: if request.auth != null && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if request.auth != null && (
        resource.data.teacherId == request.auth.uid || isAdmin()
      );
    }

    match /classes/{classId}/cohorts/{cohortId} {
      allow read: if request.auth != null && (
        ownsClass(classId) || isClassTeacher(classId) || studentCanAccessClassContent(classId) || isAdmin()
      );
      allow write: if request.auth != null && (ownsClass(classId) || isAdmin());
    }

    match /classes/{classId}/enrollments/{enrollmentId} {
      allow read: if request.auth != null && (
        ownsClass(classId) || isClassTeacher(classId) || resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if request.auth != null && (ownsClass(classId) || isAdmin());
      allow update, delete: if request.auth != null && (ownsClass(classId) || isAdmin());
    }

    // Entry requirements (NDA, end-user agreement, custom forms): teacher CRUD; students read when they have grant (to complete)
    match /classes/{classId}/entryRequirements/{reqId} {
      allow read: if request.auth != null && (
        ownsClass(classId) || (isStudent() && hasValidAccessGrant(classId)) || isAdmin()
      );
      allow create, update, delete: if request.auth != null && (ownsClass(classId) || isAdmin());
    }

    // Requirement completions: student write own; teacher read for roster
    match /classes/{classId}/requirementCompletions/{completionId} {
      allow read: if request.auth != null && (
        ownsClass(classId) || resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isStudent() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if resource.data.userId == request.auth.uid || ownsClass(classId) || isAdmin();
    }

    // Curricula: teacher CRUD own; authenticated users can read
    match /curricula/{docId} {
      allow read: if request.auth != null && (
        resource.data.teacherId == request.auth.uid || isAdmin()
      );
      allow create: if request.auth != null && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.teacherId == request.auth.uid;
    }

    match /modules/{moduleId} {
      allow read: if request.auth != null && (
        ownsClass(resource.data.classId) || studentCanAccessClassContent(resource.data.classId) || isAdmin()
      );
      allow create: if request.auth != null && (
        ownsClass(request.resource.data.classId) || isAdmin()
      );
      allow update: if request.auth != null && (
        ownsClass(request.resource.data.classId) || isAdmin()
      );
      allow delete: if request.auth != null && (
        ownsClass(resource.data.classId) || isAdmin()
      );
    }

    // Lesson placements (attach/clone across modules)
    match /lessonPlacements/{placementId} {
      allow read: if request.auth != null && (hasValidAccessGrant(resource.data.classId) || isAdmin());
      allow create: if request.auth != null && ownsClass(request.resource.data.classId);
      allow update, delete: if request.auth != null && ownsClass(resource.data.classId);
    }

    // Lessons (recorded)
    match /lessons/{lessonId} {
      allow read: if request.auth != null && (
        resource.data.ownerId == request.auth.uid
        || ownsClass(resource.data.classId) || studentCanAccessClassContent(resource.data.classId) || isAdmin()
      );
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null && (
        resource.data.ownerId == request.auth.uid || isAdmin()
      );

      match /lessonVersions/{versionId} {
        allow read, write: if request.auth != null
          && exists(/databases/$(database)/documents/lessons/$(lessonId))
          && get(/databases/$(database)/documents/lessons/$(lessonId)).data.ownerId == request.auth.uid;
      }
    }

    // Live lessons
    match /liveLessons/{lessonId} {
      allow read: if request.auth != null && (
        resource.data.ownerId == request.auth.uid
        || ownsClass(resource.data.classId) || studentCanAccessClassContent(resource.data.classId) || isAdmin()
      );
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null && (
        resource.data.ownerId == request.auth.uid || isAdmin()
      );

      // Teacher-only session plan (running order); students do not read this subcollection.
      match /teacherPlanItems/{itemId} {
        allow read, create, update, delete: if canAccessLiveLessonTeacherPlan(lessonId);
      }
    }

    // Assignments
    match /assignments/{assignmentId} {
      allow read: if request.auth != null && (
        resource.data.ownerId == request.auth.uid
        || ownsClass(resource.data.classId) || studentCanAccessClassContent(resource.data.classId) || isAdmin()
      );
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null && (
        resource.data.ownerId == request.auth.uid || isAdmin()
      );
    }

    match /assignments/{assignmentId}/submissions/{submissionId} {
      allow read: if request.auth != null && (
        ownsClass(get(/databases/$(database)/documents/assignments/$(assignmentId)).data.classId)
        || resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isStudent() && request.resource.data.userId == request.auth.uid
        && studentCanAccessClassContent(get(/databases/$(database)/documents/assignments/$(assignmentId)).data.classId);
      allow update, delete: if resource.data.userId == request.auth.uid
        || ownsClass(get(/databases/$(database)/documents/assignments/$(assignmentId)).data.classId);
    }

    // Rubrics: teacher CRUD own; students can read (e.g. when viewing assignment/feedback)
    match /rubrics/{rubricId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }

    // Rubric edit history: teacher read/write when they own the rubric
    match /rubrics/{rubricId}/editHistory/{editId} {
      allow read, write: if request.auth != null
        && get(/databases/$(database)/documents/rubrics/$(rubricId)).data.ownerId == request.auth.uid;
    }

    // Feedback: linked to submissionId + assignmentId; teacher write; student read own
    match /feedback/{feedbackId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid
        || resource.data.teacherId == request.auth.uid
        || isAdmin()
      );
      allow create: if request.auth != null && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.teacherId == request.auth.uid;
    }

    // Quizzes
    match /quizzes/{quizId} {
      allow read: if request.auth != null && (
        resource.data.ownerId == request.auth.uid
        || ownsClass(resource.data.classId) || studentCanAccessClassContent(resource.data.classId) || isAdmin()
      );
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null && (
        resource.data.ownerId == request.auth.uid || isAdmin()
      );
    }

    match /quizzes/{quizId}/questions/{qId} {
      allow read, write: if request.auth != null && (
        get(/databases/$(database)/documents/quizzes/$(quizId)).data.ownerId == request.auth.uid
        || studentCanAccessClassContent(get(/databases/$(database)/documents/quizzes/$(quizId)).data.classId)
      );
    }

    // Answer key: teacher-only; students never see correct answers
    match /quizzes/{quizId}/answerKey/{qId} {
      allow read, write: if request.auth != null
        && get(/databases/$(database)/documents/quizzes/$(quizId)).data.ownerId == request.auth.uid;
    }

    match /quizzes/{quizId}/attempts/{attemptId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid
        || ownsClass(get(/databases/$(database)/documents/quizzes/$(quizId)).data.classId)
        || isAdmin()
      );
      allow create: if isStudent() && request.resource.data.userId == request.auth.uid
        && studentCanAccessClassContent(get(/databases/$(database)/documents/quizzes/$(quizId)).data.classId);
      allow update: if resource.data.userId == request.auth.uid
        || (ownsClass(get(/databases/$(database)/documents/quizzes/$(quizId)).data.classId) || isAdmin());
      allow delete: if resource.data.userId == request.auth.uid;
    }

    // Analysis snapshots: teacher-only; students never see
    match /analysisSnapshots/{snapshotId} {
      allow read, write: if request.auth != null && (
        resource.data.createdBy == request.auth.uid
        || (request.resource != null && request.resource.data.createdBy == request.auth.uid)
      );
      allow read, write: if isAdmin();
    }

    // Communities
    match /communities/{communityId} {
      allow read: if request.auth != null && (
        resource.data.ownerId == request.auth.uid
        || ownsClass(resource.data.classId) || studentCanAccessClassContent(resource.data.classId) || isAdmin()
      );
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }

    match /communities/{communityId}/threads/{threadId} {
      allow read: if request.auth != null && (
        ownsClass(get(/databases/$(database)/documents/communities/$(communityId)).data.classId)
        || studentCanAccessClassContent(get(/databases/$(database)/documents/communities/$(communityId)).data.classId)
      );
      allow create: if request.auth != null;
      allow update, delete: if resource.data.authorId == request.auth.uid
        || ownsClass(get(/databases/$(database)/documents/communities/$(communityId)).data.classId);
    }

    // Portfolio: student-controlled; teachers can read items for classes they teach
    match /portfolioItems/{itemId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid
        || ownsClass(resource.data.classId)
        || isAdmin()
      );
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Certifications: teacher issue; student read own
    match /certifications/{certId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid
        || resource.data.issuedBy == request.auth.uid
        || isAdmin()
      );
      allow create: if request.auth != null && request.resource.data.issuedBy == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.issuedBy == request.auth.uid;
    }

    // Certificate templates: teacher CRUD for own class; admin full access
    match /certificateTemplates/{templateId} {
      allow read: if request.auth != null && (
        ownsClass(resource.data.classId)
        || studentCanAccessClassContent(resource.data.classId)
        || isAdmin()
      );
      allow create: if request.auth != null && (request.resource.data.ownerId == request.auth.uid || isAdmin());
      allow update, delete: if request.auth != null && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // Class completions: teacher read; student read own; written by Cloud Function or teacher
    match /classCompletions/{completionId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid
        || ownsClass(resource.data.classId)
        || isAdmin()
      );
      allow create: if request.auth != null && (ownsClass(request.resource.data.classId) || isAdmin());
      allow update, delete: if request.auth != null && (ownsClass(resource.data.classId) || isAdmin());
    }

    // Playlists: teacher CRUD for own class; admin full access; students read if they can access class
    match /playlists/{playlistId} {
      allow read: if request.auth != null && (
        resource.data.ownerId == request.auth.uid
        || ownsClass(resource.data.classId)
        || studentCanAccessClassContent(resource.data.classId)
        || isAdmin()
      );
      allow create: if request.auth != null && (request.resource.data.ownerId == request.auth.uid || isAdmin());
      allow update, delete: if request.auth != null && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /playlists/{playlistId}/items/{itemId} {
      allow read: if request.auth != null && (
        get(/databases/$(database)/documents/playlists/$(playlistId)).data.ownerId == request.auth.uid
        || ownsClass(get(/databases/$(database)/documents/playlists/$(playlistId)).data.classId)
        || studentCanAccessClassContent(get(/databases/$(database)/documents/playlists/$(playlistId)).data.classId)
        || isAdmin()
      );
      allow create, update, delete: if request.auth != null && (
        get(/databases/$(database)/documents/playlists/$(playlistId)).data.ownerId == request.auth.uid || isAdmin()
      );
    }

    // Playlist progress: student read/write own only
    match /users/{userId}/playlistItemProgress/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Teacher profiles (public page): read by anyone; write own
    match /teacherProfiles/{profileId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Teacher settings: teacher/admin read and write own
    match /teacherSettings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Enrollments (top-level if used)
    match /enrollments/{enrollmentId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid
        || ownsClass(resource.data.classId)
        || isAdmin()
      );
      allow create: if request.auth != null && (ownsClass(request.resource.data.classId) || isAdmin());
      allow update, delete: if request.auth != null && (ownsClass(resource.data.classId) || isAdmin());
    }

    // Teacher availability for 1-on-1 bookings: teacher/admin writes own; authenticated users read (students browse slots)
    match /teacherAvailability/{teacherId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == teacherId;
      allow update, delete: if request.auth != null && request.auth.uid == teacherId;
    }

    // Bookings: teacher or student involved can read; writes only via Cloud Functions (Admin SDK)
    match /bookings/{bookingId} {
      allow read: if request.auth != null && (
        resource.data.teacherId == request.auth.uid
        || resource.data.studentId == request.auth.uid
        || isAdmin()
      );
      allow create, update, delete: if false;
    }

    // Recording shares: teacher reads/writes own; students read shares targeting them or their class
    match /recordingShares/{shareId} {
      allow read: if request.auth != null && (
        resource.data.ownerId == request.auth.uid
        || isAdmin()
        || (isStudent() && resource.data.classId != null && hasValidAccessGrant(resource.data.classId))
      );
      allow create, update, delete: if false; // only via Cloud Functions (shareRecording)
    }

    // Rate limits: backend-only (Cloud Functions Admin SDK); no client access
    match /rateLimits/{docId} {
      allow read, write: if false;
    }
  }
}
