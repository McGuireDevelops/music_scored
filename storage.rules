rules_version = '2';
// Storage: submissions by student and class teacher; analysis snapshots teacher-only; DAW/lesson media by enrolled students.

service firebase.storage {
  match /b/{bucket}/o {

    // Assignments submissions: assignments/{assignmentId}/submissions/{submissionId}/*
    // Student can write own; student and class teacher can read
    // Custom metadata keys are lowercased by Firebase: userId -> userid, teacherId -> teacherid
    match /assignments/{assignmentId}/submissions/{submissionId}/{allPaths=**} {
      allow read: if request.auth != null && (
        resource.metadata['userid'] == request.auth.uid
        || resource.metadata['teacherid'] == request.auth.uid
      );
      allow write: if request.auth != null && request.resource.metadata['userid'] == request.auth.uid
        && request.resource.size < 50 * 1024 * 1024;
    }

    // Analysis snapshots: teacher-only; max 10MB on write
    match /analysisSnapshots/{allPaths=**} {
      allow read: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['teacher', 'admin'];
      allow write: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['teacher', 'admin']
        && request.resource.size < 10 * 1024 * 1024;
    }

    // Class lesson media and DAW templates: readable by enrolled students and class teacher; max 100MB
    match /classes/{classId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && firestore.get(/databases/(default)/documents/classes/$(classId)).data.teacherId == request.auth.uid
        && request.resource.size < 100 * 1024 * 1024;
    }

    // User feedback uploads (voice/video): teacher write; student (subject) and teacher read; max 50MB
    // Custom metadata keys are lowercased by Firebase: userId -> userid, teacherId -> teacherid
    match /users/{userId}/feedback/{allPaths=**} {
      allow read: if request.auth != null && (
        resource.metadata['userid'] == request.auth.uid
        || resource.metadata['teacherid'] == request.auth.uid
      );
      allow write: if request.auth != null && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['teacher', 'admin']
        && request.resource.size < 50 * 1024 * 1024;
    }

    // Tenant branding (logo, favicon): teacher write own; public read for white-label display
    match /tenants/{teacherId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == teacherId
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['teacher', 'admin']
        && request.resource.size < 2 * 1024 * 1024;
    }
  }
}
